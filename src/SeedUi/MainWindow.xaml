<hc:Window x:Class="SeedUi.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:vm="clr-namespace:SeedUi.ViewModels"
           xmlns:views="clr-namespace:SeedUi.Views"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           mc:Ignorable="d"
           Title="开局种子筛选器"
           WindowStartupLocation="CenterScreen"
           Height="900"
           Width="1400"
           MinWidth="1200"
           MinHeight="700"
           Background="#F5F7FA"
           Loaded="OnLoaded">

    <hc:Window.DataContext>
        <vm:MainWindowViewModel/>
    </hc:Window.DataContext>

    <hc:Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanVisibilityConverter"/>

        <!-- 导航按钮样式 -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="Nav"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="Transparent" Padding="20 0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{TemplateBinding Tag}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="18"
                                           VerticalAlignment="Center"
                                           x:Name="Icon"/>
                                <TextBlock Grid.Column="2" Text="{TemplateBinding Content}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           x:Name="Text"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="Icon" Property="Foreground" Value="#1976D2"/>
                                <Setter TargetName="Text" Property="Foreground" Value="#1976D2"/>
                                <Setter TargetName="Text" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Icon" Property="Foreground" Value="#666"/>
                                <Setter TargetName="Text" Property="Foreground" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.1" Color="#000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 筛选标签样式 -->
        <Style x:Key="FilterTagStyle" TargetType="Border">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="BorderBrush" Value="#BBDEFB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8 4"/>
            <Setter Property="Margin" Value="0 4 8 4"/>
        </Style>

        <Style x:Key="PoolResultEventNameStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="Margin" Value="0 2 0 2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="TextDecorations" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#8A5A00"/>
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PoolResultTooltipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#F6E6A9"/>
            <Setter Property="BorderBrush" Value="#B28B2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#3E2B00"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Placement" Value="Mouse"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>
    </hc:Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Grid.Row="0" Background="White" BorderBrush="#E8E8E8" BorderThickness="0 0 1 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo区域 -->
                <Border Grid.Row="0" Padding="20" BorderBrush="#E8E8E8" BorderThickness="0 0 0 1">
                    <StackPanel>
                        <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="#1976D2" Margin="0 0 0 8"/>
                        <TextBlock Text="开局种子筛选器" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock Text="Slay the Spire 2" FontSize="12" Foreground="#999" Margin="0 4 0 0"/>
                    </StackPanel>
                </Border>

                <!-- 导航按钮 - 三个页面 -->
                <StackPanel Grid.Row="1" Margin="0 16">
                    <RadioButton x:Name="NavConfig" Style="{StaticResource NavButtonStyle}"
                                 Content="配置" Tag="&#xE713;" IsChecked="True"
                                 Checked="NavConfig_Checked"/>
                    <RadioButton x:Name="NavSeedAnalysis" Style="{StaticResource NavButtonStyle}"
                                 Content="种子分析" Tag="&#xE8B7;"
                                 Checked="NavSeedAnalysis_Checked"/>
                    <RadioButton x:Name="NavResult" Style="{StaticResource NavButtonStyle}"
                                 Content="运行结果" Tag="&#xE9D2;"
                                 Checked="NavResult_Checked"/>
                    <RadioButton x:Name="NavLogs" Style="{StaticResource NavButtonStyle}"
                                 Content="运行日志" Tag="&#xE7BA;"
                                 Checked="NavLogs_Checked"/>
                    <RadioButton x:Name="NavArchive" Style="{StaticResource NavButtonStyle}"
                                 Content="铺种" Tag="&#xE7C3;"
                                 Checked="NavArchive_Checked"/>
                    <RadioButton x:Name="NavViewer" Style="{StaticResource NavButtonStyle}"
                                 Content="查看器" Tag="&#xE8A5;"
                                 Checked="NavViewer_Checked"/>
                </StackPanel>

                <!-- 底部数据状态 -->
                <Border Grid.Row="2" Padding="16" BorderBrush="#E8E8E8" BorderThickness="0 1 0 0">
                    <TextBlock Text="{Binding DatasetSummary}" FontSize="11" Foreground="#999" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Column="1" Grid.Row="0" Background="#F5F7FA">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E8E8E8" BorderThickness="0 0 0 1" Padding="24 16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock x:Name="PageTitle" Text="配置" FontSize="20" FontWeight="SemiBold" Foreground="#333"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="重置配置" Click="OnResetConfig" Style="{StaticResource ButtonDefault}" Margin="0 0 8 0"/>
                        <Button Content="加载配置" Click="OnLoadConfig" Style="{StaticResource ButtonDefault}" Margin="0 0 8 0"/>
                        <Button Content="保存配置" Click="OnSaveConfig" Style="{StaticResource ButtonDefault}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容面板 -->
            <Grid Grid.Row="1" Background="#F5F7FA">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ========== 配置页面（基础设置 + 筛选配置） ========== -->
                <ScrollViewer x:Name="PageConfigScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24">
                    <Grid x:Name="PageConfig">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左列：事件、角色、遗物、卡牌、药水 -->
                        <StackPanel Grid.Column="0" Margin="0 0 12 0">
                            <!-- 事件与数据 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <TextBlock Text="版本与数据" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 16" Foreground="#333"/>
                                    <TextBlock Text="游戏版本" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                    <ComboBox ItemsSource="{Binding GameVersionOptions}" DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding SelectedGameVersion}" Margin="0 0 0 12" MinHeight="25" VerticalContentAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedGameVersionStatusText}" FontSize="12" Foreground="#999" Margin="0 0 0 4"/>
                                </StackPanel>
                            </Border>

                            <!-- 角色设置 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <TextBlock Text="角色设置" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 16" Foreground="#333"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                            <TextBlock Text="角色" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                            <ComboBox ItemsSource="{Binding CharacterOptions}" DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Id" SelectedValue="{Binding SelectedCharacter}" MinHeight="25" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8 0 0 0">
                                            <TextBlock Text="进阶等级" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                            <ComboBox ItemsSource="{Binding AscensionOptions}" SelectedValue="{Binding SelectedAscensionLevel}" MinHeight="25" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 遗物筛选 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <TextBlock Text="遗物筛选" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 8" Foreground="#333"/>
                                    <TextBlock Text="选择特定的遗物来筛选符合条件的种子" FontSize="12" Foreground="#999" Margin="0 0 0 16"/>

                                    <TextBlock Text="搜索遗物" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                    <TextBox Text="{Binding RelicCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                             hc:InfoElement.Placeholder="输入名称或ID过滤遗物列表..." Margin="0 0 0 12" Height="30"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding RelicCatalogView}" DisplayMemberPath="Display"
                                                  SelectedItem="{Binding SelectedRelicCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                        <Button Grid.Column="1" Content="添加" Command="{Binding AddRelicFilterCommand}"
                                                Style="{StaticResource ButtonPrimary}"/>
                                    </Grid>

                                    <TextBlock Text="已选遗物" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                    <ItemsControl ItemsSource="{Binding RelicFilterChips}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FilterTagStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                        <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                Command="{Binding DataContext.RemoveRelicFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                Style="{StaticResource GhostButtonStyle}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                            <!-- 卡牌筛选 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <TextBlock Text="卡牌筛选" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 8" Foreground="#333"/>
                                    <TextBlock Text="可按中文名、拼音或ID过滤卡牌" FontSize="12" Foreground="#999" Margin="0 0 0 16"/>

                                    <TextBlock Text="搜索卡牌" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                    <TextBox Text="{Binding CardCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                             hc:InfoElement.Placeholder="输入文字过滤卡牌列表..." Margin="0 0 0 12" Height="30"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding CardCatalogView}" DisplayMemberPath="Display"
                                                  SelectedItem="{Binding SelectedCardCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                        <Button Grid.Column="1" Content="添加" Command="{Binding AddCardFilterCommand}"
                                                Style="{StaticResource ButtonPrimary}"/>
                                    </Grid>

                                    <TextBlock Text="已选卡牌" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                    <ItemsControl ItemsSource="{Binding CardFilterChips}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FilterTagStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                        <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                Command="{Binding DataContext.RemoveCardFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                Style="{StaticResource GhostButtonStyle}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- 药水筛选 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <TextBlock Text="药水筛选" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 8" Foreground="#333"/>
                                    <TextBlock Text="支持输入药水名称或ID过滤" FontSize="12" Foreground="#999" Margin="0 0 0 16"/>

                                    <TextBlock Text="搜索药水" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                    <TextBox Text="{Binding PotionCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                             hc:InfoElement.Placeholder="输入文字过滤药水列表..." Margin="0 0 0 12" Height="30"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding PotionCatalogView}" DisplayMemberPath="Display"
                                                  SelectedItem="{Binding SelectedPotionCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                        <Button Grid.Column="1" Content="添加" Command="{Binding AddPotionFilterCommand}"
                                                Style="{StaticResource ButtonPrimary}"/>
                                    </Grid>

                                    <TextBlock Text="已选药水" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                    <ItemsControl ItemsSource="{Binding PotionFilterChips}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FilterTagStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                        <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                Command="{Binding DataContext.RemovePotionFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                Style="{StaticResource GhostButtonStyle}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- 种子分析筛选 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                                        <TextBlock Text="种子分析筛选" FontSize="16" FontWeight="SemiBold" Foreground="#333"/>
                                        <CheckBox IsChecked="{Binding IncludePoolFilter}" Content="启用" Margin="16 0 0 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="基于种子分析中的事件池与遗物概率预览进行命中筛选" FontSize="11" Foreground="#888" Margin="8 0 0 0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding PoolFilterSummary}" Foreground="#666" TextWrapping="Wrap" Margin="0 0 0 16"/>

                                    <StackPanel IsEnabled="{Binding IncludePoolFilter}">
                                        <TextBlock Text="事件池" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                        <Grid Margin="0 0 0 16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                                <TextBlock Text="第一幕事件" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                                                <TextBox Text="{Binding Act1EventPoolCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                                         hc:InfoElement.Placeholder="输入文字过滤事件列表..." Margin="0 0 0 6" Height="30"/>
                                                <Grid Margin="0 0 0 6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0" ItemsSource="{Binding Act1EventPoolCatalogView}" DisplayMemberPath="Display"
                                                              SelectedItem="{Binding SelectedAct1EventPoolCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="添加" Command="{Binding AddAct1EventPoolFilterCommand}" Style="{StaticResource ButtonDefault}"/>
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding Act1EventPoolFilterChips}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource FilterTagStyle}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                                    <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                            Command="{Binding DataContext.RemoveAct1EventPoolFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                            Style="{StaticResource GhostButtonStyle}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="8 0">
                                                <TextBlock Text="第二幕事件" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                                                <TextBox Text="{Binding Act2EventPoolCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                                         hc:InfoElement.Placeholder="输入文字过滤事件列表..." Margin="0 0 0 6" Height="30"/>
                                                <Grid Margin="0 0 0 6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0" ItemsSource="{Binding Act2EventPoolCatalogView}" DisplayMemberPath="Display"
                                                              SelectedItem="{Binding SelectedAct2EventPoolCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="添加" Command="{Binding AddAct2EventPoolFilterCommand}" Style="{StaticResource ButtonDefault}"/>
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding Act2EventPoolFilterChips}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource FilterTagStyle}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                                    <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                            Command="{Binding DataContext.RemoveAct2EventPoolFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                            Style="{StaticResource GhostButtonStyle}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Margin="8 0 0 0">
                                                <TextBlock Text="第三幕事件" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                                                <TextBox Text="{Binding Act3EventPoolCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                                         hc:InfoElement.Placeholder="输入文字过滤事件列表..." Margin="0 0 0 6" Height="30"/>
                                                <Grid Margin="0 0 0 6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0" ItemsSource="{Binding Act3EventPoolCatalogView}" DisplayMemberPath="Display"
                                                              SelectedItem="{Binding SelectedAct3EventPoolCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="添加" Command="{Binding AddAct3EventPoolFilterCommand}" Style="{StaticResource ButtonDefault}"/>
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding Act3EventPoolFilterChips}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource FilterTagStyle}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                                    <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                            Command="{Binding DataContext.RemoveAct3EventPoolFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                            Style="{StaticResource GhostButtonStyle}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="高概率出现遗物" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                        <Grid Margin="0 0 0 8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="概率阈值(%)" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0 0 8 0"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding HighProbabilitySeenThresholdPercentText, UpdateSourceTrigger=PropertyChanged}"
                                                     Height="28"
                                                     VerticalContentAlignment="Center"
                                                     Margin="0 0 8 0"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding HighProbabilitySeenThresholdDescription}"
                                                       FontSize="11"
                                                       Foreground="#888"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                        <StackPanel>
                                            <TextBox Text="{Binding HighProbabilityRelicCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                                     hc:InfoElement.Placeholder="输入文字过滤遗物列表..." Margin="0 0 0 6" Height="30"/>
                                            <Grid Margin="0 0 0 6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" ItemsSource="{Binding HighProbabilityRelicCatalogView}" DisplayMemberPath="Display"
                                                          SelectedItem="{Binding SelectedHighProbabilityRelicCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                                <Button Grid.Column="1" Content="添加" Command="{Binding AddHighProbabilityRelicFilterCommand}" Style="{StaticResource ButtonDefault}"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding HighProbabilityRelicFilterChips}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource FilterTagStyle}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                        Command="{Binding DataContext.RemoveHighProbabilityRelicFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                        Style="{StaticResource GhostButtonStyle}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 右列：种子、输出、古神、开始按钮 -->
                        <StackPanel Grid.Column="1" Margin="12 0 0 0">
                            <!-- 种子设置 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <TextBlock Text="种子设置" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 16" Foreground="#333"/>

                                    <TextBlock Text="种子模式" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                    <ComboBox ItemsSource="{Binding SeedModeOptions}" DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value" SelectedValue="{Binding SelectedSeedMode}" Margin="0 0 0 16" MinHeight="25" VerticalContentAlignment="Center"/>

                                    <TextBlock Text="起始种子" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                    <TextBox Text="{Binding SeedText, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsIncrementalMode}" Margin="0 0 0 16"
                                             hc:InfoElement.Placeholder="输入起始种子..." Height="30"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0 0 8 0">
                                            <TextBlock Text="Roll 数量" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                            <TextBox Text="{Binding RollCount, UpdateSourceTrigger=PropertyChanged}" hc:InfoElement.Placeholder="100" Height="30"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8 0 0 0">
                                            <TextBlock Text="种子步长" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                            <TextBox Text="{Binding SeedStep, UpdateSourceTrigger=PropertyChanged}" hc:InfoElement.Placeholder="1" Height="30"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 提示 -->
                            <Border Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="1" CornerRadius="8"
                                    Padding="16" Margin="0 0 0 16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#F57C00" Margin="0 0 12 0"/>
                                    <TextBlock Text="{Binding AncientPreviewStatusText}" Foreground="#666" TextWrapping="Wrap" FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <!-- 第二幕古神 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                                        <TextBlock Text="第二幕古神" FontSize="16" FontWeight="SemiBold" Foreground="#333"/>
                                        <CheckBox IsChecked="{Binding IncludeAct2}" Content="启用" Margin="16 0 0 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="可能因局内游戏随机变化而产生变化，非100%命中" FontSize="11" Foreground="#888" Margin="8 0 0 0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="280"/>
                                    </StackPanel>

                                    <StackPanel IsEnabled="{Binding IncludeAct2}">
                                        <TextBlock Text="古神类型" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                        <ComboBox ItemsSource="{Binding Act2FilterOptions}" DisplayMemberPath="DisplayText"
                                                  SelectedValuePath="Id" SelectedValue="{Binding Act2AncientFilter}" Margin="0 0 0 16" MinHeight="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="遗物选项" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" ItemsSource="{Binding Act2RelicOptions}" DisplayMemberPath="DisplayText"
                                                      SelectedItem="{Binding SelectedAct2RelicOption}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                            <Button Grid.Column="1" Content="添加" Command="{Binding AddAct2OptionFilterCommand}"
                                                    Style="{StaticResource ButtonDefault}"/>
                                        </Grid>

                                        <TextBlock Text="已选选项" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                        <ItemsControl ItemsSource="{Binding Act2OptionFilterChips}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource FilterTagStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                    Command="{Binding DataContext.RemoveAct2OptionFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                    Style="{StaticResource GhostButtonStyle}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 第三幕古神 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                                        <TextBlock Text="第三幕古神" FontSize="16" FontWeight="SemiBold" Foreground="#333"/>
                                        <CheckBox IsChecked="{Binding IncludeAct3}" Content="启用" Margin="16 0 0 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="可能因局内游戏随机变化而产生变化，非100%命中" FontSize="11" Foreground="#888" Margin="8 0 0 0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="280"/>
                                    </StackPanel>

                                    <StackPanel IsEnabled="{Binding IncludeAct3}">
                                        <TextBlock Text="古神类型" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                        <ComboBox ItemsSource="{Binding Act3FilterOptions}" DisplayMemberPath="DisplayText"
                                                  SelectedValuePath="Id" SelectedValue="{Binding Act3AncientFilter}" Margin="0 0 0 16" MinHeight="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="遗物选项" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" ItemsSource="{Binding Act3RelicOptions}" DisplayMemberPath="DisplayText"
                                                      SelectedItem="{Binding SelectedAct3RelicOption}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                            <Button Grid.Column="1" Content="添加" Command="{Binding AddAct3OptionFilterCommand}"
                                                    Style="{StaticResource ButtonDefault}"/>
                                        </Grid>

                                        <TextBlock Text="已选选项" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                        <ItemsControl ItemsSource="{Binding Act3OptionFilterChips}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource FilterTagStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                    Command="{Binding DataContext.RemoveAct3OptionFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                    Style="{StaticResource GhostButtonStyle}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 商店筛选 -->
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                                        <TextBlock Text="商店筛选" FontSize="16" FontWeight="SemiBold" Foreground="#333"/>
                                        <CheckBox IsChecked="{Binding IncludeShop}" Content="启用" Margin="16 0 0 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="模拟第一幕商店，筛选卡牌/遗物/药水" FontSize="11" Foreground="#888" Margin="8 0 0 0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                                    </StackPanel>

                                    <StackPanel IsEnabled="{Binding IncludeShop}">
                                        <TextBlock Text="第一家商店最远层数" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                        <TextBox Text="{Binding ShopMaxFirstRow, UpdateSourceTrigger=PropertyChanged}"
                                                 hc:InfoElement.Placeholder="留空表示不限，例如 2 表示第一家商店最晚出现在第 2 层" Margin="0 0 0 12" Height="30"/>
                                        <!-- 卡牌 -->
                                        <TextBlock Text="搜索卡牌" FontSize="13" Foreground="#666" Margin="0 0 0 8"/>
                                        <TextBox Text="{Binding ShopCardCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                                 hc:InfoElement.Placeholder="输入文字过滤卡牌列表..." Margin="0 0 0 12" Height="30"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" ItemsSource="{Binding ShopCardCatalogView}" DisplayMemberPath="Display"
                                                      SelectedItem="{Binding SelectedShopCardCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                            <Button Grid.Column="1" Content="添加" Command="{Binding AddShopCardFilterCommand}"
                                                    Style="{StaticResource ButtonPrimary}"/>
                                        </Grid>
                                        <TextBlock Text="已选卡牌" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                        <ItemsControl ItemsSource="{Binding ShopCardFilterChips}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource FilterTagStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                    Command="{Binding DataContext.RemoveShopCardFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                    Style="{StaticResource GhostButtonStyle}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 遗物 -->
                                        <TextBlock Text="搜索遗物" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                        <TextBox Text="{Binding ShopRelicCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                                 hc:InfoElement.Placeholder="输入文字过滤遗物列表..." Margin="0 0 0 12" Height="30"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" ItemsSource="{Binding ShopRelicCatalogView}" DisplayMemberPath="Display"
                                                      SelectedItem="{Binding SelectedShopRelicCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                            <Button Grid.Column="1" Content="添加" Command="{Binding AddShopRelicFilterCommand}"
                                                    Style="{StaticResource ButtonPrimary}"/>
                                        </Grid>
                                        <TextBlock Text="已选遗物" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                        <ItemsControl ItemsSource="{Binding ShopRelicFilterChips}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource FilterTagStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                    Command="{Binding DataContext.RemoveShopRelicFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                    Style="{StaticResource GhostButtonStyle}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 药水 -->
                                        <TextBlock Text="搜索药水" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                        <TextBox Text="{Binding ShopPotionCatalogFilter, UpdateSourceTrigger=PropertyChanged}"
                                                 hc:InfoElement.Placeholder="输入文字过滤药水列表..." Margin="0 0 0 12" Height="30"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" ItemsSource="{Binding ShopPotionCatalogView}" DisplayMemberPath="Display"
                                                      SelectedItem="{Binding SelectedShopPotionCatalogItem}" Margin="0 0 8 0" MinHeight="25" VerticalContentAlignment="Center"/>
                                            <Button Grid.Column="1" Content="添加" Command="{Binding AddShopPotionFilterCommand}"
                                                    Style="{StaticResource ButtonPrimary}"/>
                                        </Grid>
                                        <TextBlock Text="已选药水" FontSize="13" Foreground="#666" Margin="0 16 0 8"/>
                                        <ItemsControl ItemsSource="{Binding ShopPotionFilterChips}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource FilterTagStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Label}" Foreground="#1976D2" FontSize="12"/>
                                                            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                    Command="{Binding DataContext.RemoveShopPotionFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding Id}" Margin="6 0 0 0" Padding="2"
                                                                    Style="{StaticResource GhostButtonStyle}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 开始Roll按钮 -->
                            <Border Style="{StaticResource CardStyle}" Background="#1976D2" BorderBrush="#1565C0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="White">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="配置完成？开始Roll种子！"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRolling}" Value="True">
                                                            <Setter Property="Text" Value="正在扫描中…"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#E3F2FD" Margin="0 4 0 0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="系统将扫描符合条件的种子并显示结果"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRolling}" Value="True">
                                                            <Setter Property="Text" Value="{Binding RollProgressText}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Command="{Binding RollCommand}"
                                                Padding="40 16" FontSize="16" FontWeight="Bold" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="Foreground" Value="#1976D2"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="#E0E0E0"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter TargetName="Border" Property="Background" Value="#BDBDBD"/>
                                                                        <Setter Property="Foreground" Value="#757575"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="开始 Roll"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRolling}" Value="True">
                                                                <Setter Property="Text" Value="Roll 中…"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <Button Command="{Binding CancelCommand}"
                                                Padding="20 16" FontSize="14" Margin="12 0 0 0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="White"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="White"/>
                                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="#E3F2FD"/>
                                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                                                        <Setter TargetName="Border" Property="BorderBrush" Value="#90CAF9"/>
                                                                        <Setter Property="Foreground" Value="#90CAF9"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="取消"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRolling}" Value="True">
                                                                <Setter Property="Text" Value="停止"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- ========== 运行结果页面 ========== -->
                <ScrollViewer x:Name="PageSeedAnalysisScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24" Visibility="Collapsed">
                    <views:SeedAnalysisPage x:Name="PageSeedAnalysis"/>
                </ScrollViewer>

                <ScrollViewer x:Name="PageResultScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24">
                    <Grid x:Name="PageResult" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 统计卡片 -->
                        <Grid Grid.Row="0" Margin="0 0 0 16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0 0 8 0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#1976D2" Margin="0 0 0 8"/>
                                    <TextBlock Text="{Binding ScannedSeeds}" FontSize="32" FontWeight="Bold" Foreground="#1976D2" HorizontalAlignment="Center"/>
                                    <TextBlock Text="已扫描种子" FontSize="13" Foreground="#666" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8 0 8 0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE930;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#4CAF50" Margin="0 0 0 8"/>
                                    <TextBlock Text="{Binding HitSeeds}" FontSize="32" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                                    <TextBlock Text="命中种子" FontSize="13" Foreground="#666" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8 0 8 0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8BC;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#FF9800" Margin="0 0 0 8"/>
                                    <TextBlock Text="{Binding HitOptions}" FontSize="32" FontWeight="Bold" Foreground="#FF9800" HorizontalAlignment="Center"/>
                                    <TextBlock Text="命中选项" FontSize="13" Foreground="#666" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="8 0 0 0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#00BCD4" Margin="0 0 0 8"/>
                                    <TextBlock Text="{Binding Results.Count}" FontSize="32" FontWeight="Bold" Foreground="#00BCD4" HorizontalAlignment="Center"/>
                                    <TextBlock Text="结果数量" FontSize="13" Foreground="#666" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 操作按钮 -->
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                            <StackPanel>
                                <WrapPanel>
                                    <Button Content="清空结果" Command="{Binding ClearResultsCommand}"
                                            Style="{StaticResource ButtonDefault}" Margin="0 0 12 0"/>
                                    <Button Content="导出结果" Command="{Binding ExportResultsCommand}"
                                            Style="{StaticResource ButtonDefault}"/>
                                </WrapPanel>
                                <ProgressBar Value="{Binding ScannedSeeds, Mode=OneWay}"
                                             Maximum="{Binding ProgressMaximum, Mode=OneWay, FallbackValue=1}"
                                             Margin="0 16 0 0" Height="6" Background="#E3F2FD" Foreground="#1976D2"/>
                            </StackPanel>
                        </Border>

                        <!-- 命中结果 -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="命中结果" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0 0 0 12"/>
                                <Border Grid.Row="1" Background="#FAFAFA" CornerRadius="4" Padding="12">
                                    <ListBox x:Name="ResultsListBox" ItemsSource="{Binding Results}" BorderThickness="0" Background="Transparent"
                                             VirtualizingStackPanel.IsVirtualizing="True" PreviewMouseWheel="ResultsListBox_PreviewMouseWheel">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1"
                                                        CornerRadius="6" Padding="16" Margin="0 0 0 12">
                                                    <StackPanel>
                                                        <!-- 头部：种子、角色、复制按钮 -->
                                                        <DockPanel Margin="0 0 0 12">
                                                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                                <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#1976D2" Margin="0 0 8 0"/>
                                                                <TextBlock Text="{Binding SeedText}" FontWeight="Bold" FontSize="15" Foreground="#1976D2"/>
                                                                <Border Background="#F5F5F5" CornerRadius="4" Padding="6 2" Margin="12 0 0 0">
                                                                    <TextBlock Text="{Binding CharacterName}" Foreground="#666" FontSize="12"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <Button Content="复制" Command="{Binding DataContext.CopyResultCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                    CommandParameter="{Binding}" Style="{StaticResource ButtonPrimary}"
                                                                    HorizontalAlignment="Right" DockPanel.Dock="Right" FontSize="12"/>
                                                        </DockPanel>

                                                        <!-- 第一幕选项 -->
                                                        <TextBlock Text="&#xE70F; 命中的选项" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0 0 0 8"/>
                                                        <ItemsControl ItemsSource="{Binding Options}" Margin="0 0 0 12">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 8">
                                                                        <StackPanel>
                                                                            <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Foreground="#1976D2"/>
                                                                                <Border Background="#1976D2" CornerRadius="3" Padding="4 2" Margin="8 0 0 0">
                                                                                    <TextBlock Text="{Binding Kind}" FontSize="10" Foreground="White"/>
                                                                                </Border>
                                                                            </StackPanel>
                                                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#666" TextWrapping="Wrap"
                                                                                       Visibility="{Binding HasDescription, Converter={StaticResource BooleanVisibilityConverter}}" Margin="0 0 0 4"/>
                                                                            <TextBlock Text="{Binding Note}" FontSize="11" Foreground="#999" FontStyle="Italic" TextWrapping="Wrap"
                                                                                       Visibility="{Binding HasNote, Converter={StaticResource BooleanVisibilityConverter}}" Margin="0 0 0 4"/>
                                                                            <ItemsControl ItemsSource="{Binding Details}" Margin="4 4 0 0">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <StackPanel Orientation="Horizontal" Margin="0 2">
                                                                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#4CAF50" Margin="0 0 6 0"/>
                                                                                            <TextBlock Text="{Binding}" FontSize="12" Foreground="#333"/>
                                                                                        </StackPanel>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <!-- 古神信息（如果有） -->
                                                        <ItemsControl ItemsSource="{Binding AncientActs}" Visibility="{Binding HasAncientActs, Converter={StaticResource BooleanVisibilityConverter}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 8">
                                                                        <StackPanel>
                                                                            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                                                                <TextBlock Text="&#xE7C5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#F57C00" Margin="0 0 6 0"/>
                                                                                <TextBlock Text="{Binding ActTitle}" FontWeight="SemiBold" FontSize="13" Foreground="#F57C00"/>
                                                                                <TextBlock Text="{Binding AncientDisplay}" FontSize="12" Foreground="#666" Margin="12 0 0 0"/>
                                                                            </StackPanel>
                                                                            <ItemsControl ItemsSource="{Binding Options}" Visibility="{Binding HasOptions, Converter={StaticResource BooleanVisibilityConverter}}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <StackPanel Margin="0 4 0 0">
                                                                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                                                                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#666" TextWrapping="Wrap"
                                                                                                       Visibility="{Binding HasDescription, Converter={StaticResource BooleanVisibilityConverter}}"/>
                                                                                            <TextBlock Text="{Binding Note}" FontSize="11" Foreground="#999" FontStyle="Italic" TextWrapping="Wrap"
                                                                                                       Visibility="{Binding HasNote, Converter={StaticResource BooleanVisibilityConverter}}" Margin="0 2 0 0"/>
                                                                                        </StackPanel>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <!-- 商店信息 -->
                                                        <Border Visibility="{Binding HasPoolAnalysis, Converter={StaticResource BooleanVisibilityConverter}}"
                                                                Background="#F3E5F5" BorderBrush="#E1BEE7" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 8">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#7B1FA2" Margin="0 0 6 0"/>
                                                                    <TextBlock Text="种子分析命中" FontWeight="SemiBold" FontSize="13" Foreground="#7B1FA2"/>
                                                                </StackPanel>
                                                                <TextBlock Text="说明：这里的事件池是固定候选顺序；遗物部分改为概率预览，用来表示在不同路线画像下更可能实际看到的遗物。"
                                                                           FontSize="11"
                                                                           Foreground="#7B1FA2"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0 0 0 8"/>
                                                                <TextBlock Text="补充：起始遗物、古神遗物，以及部分事件直接发放的固定遗物，不属于随机遗物池；它们会在游戏中出现，但不会参与这里的随机遗物概率预览。"
                                                                           FontSize="11"
                                                                           Foreground="#7B1FA2"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0 0 0 8"/>
                                                                <ItemsControl ItemsSource="{Binding PoolActs}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Expander Header="{Binding Title}" Margin="0 0 0 8">
                                                                                <ItemsControl ItemsSource="{Binding Events}" Margin="0 6 0 0">
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <Border Margin="0 2 0 2" Padding="8 4" CornerRadius="4" BorderThickness="1">
                                                                                                <Border.Style>
                                                                                                    <Style TargetType="Border">
                                                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                                                                        <Style.Triggers>
                                                                                                            <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                                                                                <Setter Property="Background" Value="#FFF8E1"/>
                                                                                                                <Setter Property="BorderBrush" Value="#FFCC80"/>
                                                                                                            </DataTrigger>
                                                                                                        </Style.Triggers>
                                                                                                    </Style>
                                                                                                </Border.Style>
                                                                                                <TextBlock Text="{Binding Title}">
                                                                                                    <TextBlock.Style>
                                                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PoolResultEventNameStyle}">
                                                                                                            <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                                                                                    <Setter Property="Foreground" Value="#C77800"/>
                                                                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                                                </DataTrigger>
                                                                                                            </Style.Triggers>
                                                                                                        </Style>
                                                                                                    </TextBlock.Style>
                                                                                                    <TextBlock.ToolTip>
                                                                                                        <ToolTip Style="{StaticResource PoolResultTooltipStyle}"
                                                                                                                 Visibility="{Binding HasTooltipContent, Converter={StaticResource BooleanVisibilityConverter}}">
                                                                                                            <StackPanel MaxWidth="420">
                                                                                                                <TextBlock Text="{Binding Description}"
                                                                                                                           TextWrapping="Wrap"
                                                                                                                           Foreground="#3E2B00"
                                                                                                                           Visibility="{Binding HasDescription, Converter={StaticResource BooleanVisibilityConverter}}"/>
                                                                                                                <Border Height="1"
                                                                                                                        Margin="0 8 0 8"
                                                                                                                        Background="#C8A24A"
                                                                                                                        Visibility="{Binding HasDescriptionAndOptions, Converter={StaticResource BooleanVisibilityConverter}}"/>
                                                                                                                <StackPanel Visibility="{Binding HasOptions, Converter={StaticResource BooleanVisibilityConverter}}">
                                                                                                                    <TextBlock Text="可选项"
                                                                                                                               FontWeight="SemiBold"
                                                                                                                               Margin="0 0 0 6"
                                                                                                                               Foreground="#6D4900"/>
                                                                                                                    <ItemsControl ItemsSource="{Binding Options}">
                                                                                                                        <ItemsControl.ItemTemplate>
                                                                                                                            <DataTemplate>
                                                                                                                                <Border Padding="0 0 0 8">
                                                                                                                                    <StackPanel>
                                                                                                                                        <TextBlock Text="{Binding Title}"
                                                                                                                                                   FontWeight="SemiBold"
                                                                                                                                                   Foreground="#3E2B00"
                                                                                                                                                   TextWrapping="Wrap"/>
                                                                                                                                        <TextBlock Text="{Binding Description}"
                                                                                                                                                   Margin="0 2 0 0"
                                                                                                                                                   TextWrapping="Wrap"
                                                                                                                                                   Foreground="#3E2B00"
                                                                                                                                                   Visibility="{Binding HasDescription, Converter={StaticResource BooleanVisibilityConverter}}"/>
                                                                                                                                    </StackPanel>
                                                                                                                                </Border>
                                                                                                                            </DataTemplate>
                                                                                                                        </ItemsControl.ItemTemplate>
                                                                                                                    </ItemsControl>
                                                                                                                </StackPanel>
                                                                                                            </StackPanel>
                                                                                                        </ToolTip>
                                                                                                    </TextBlock.ToolTip>
                                                                                                </TextBlock>
                                                                                            </Border>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>
                                                                            </Expander>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <StackPanel Margin="0 4 0 0">
                                                                    <TextBlock Text="高概率出现遗物" FontSize="12" FontWeight="SemiBold" Foreground="#666" Margin="0 0 0 6"/>
                                                                    <ItemsControl ItemsSource="{Binding RelicVisibilityProfiles}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Expander Header="{Binding Title}" Margin="0 0 0 8">
                                                                                    <StackPanel Margin="0 6 0 0">
                                                                                        <TextBlock Text="{Binding Description}"
                                                                                                   Foreground="#666"
                                                                                                   TextWrapping="Wrap"
                                                                                                   Visibility="{Binding HasDescription, Converter={StaticResource BooleanVisibilityConverter}}"/>
                                                                                        <ItemsControl ItemsSource="{Binding Relics}" Margin="0 8 0 0">
                                                                                            <ItemsControl.ItemTemplate>
                                                                                                <DataTemplate>
                                                                                                    <Border Margin="0 2 0 2" Padding="8 4" CornerRadius="4" BorderThickness="1">
                                                                                                        <Border.Style>
                                                                                                            <Style TargetType="Border">
                                                                                                                <Setter Property="Background" Value="Transparent"/>
                                                                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                                                                <Style.Triggers>
                                                                                                                    <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                                                                                        <Setter Property="Background" Value="#FFF8E1"/>
                                                                                                                        <Setter Property="BorderBrush" Value="#FFCC80"/>
                                                                                                                    </DataTrigger>
                                                                                                                </Style.Triggers>
                                                                                                            </Style>
                                                                                                        </Border.Style>
                                                                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" TextWrapping="Wrap">
                                                                                                            <TextBlock.Style>
                                                                                                                <Style TargetType="TextBlock">
                                                                                                                    <Setter Property="Foreground" Value="#333"/>
                                                                                                                    <Style.Triggers>
                                                                                                                        <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                                                                                            <Setter Property="Foreground" Value="#C77800"/>
                                                                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                                                        </DataTrigger>
                                                                                                                    </Style.Triggers>
                                                                                                                </Style>
                                                                                                            </TextBlock.Style>
                                                                                                        </TextBlock>
                                                                                                    </Border>
                                                                                                </DataTemplate>
                                                                                            </ItemsControl.ItemTemplate>
                                                                                        </ItemsControl>
                                                                                    </StackPanel>
                                                                                </Expander>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Visibility="{Binding HasShopPreview, Converter={StaticResource BooleanVisibilityConverter}}"
                                                                Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 8 0 0">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                                                    <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#388E3C" Margin="0 0 6 0"/>
                                                                    <TextBlock Text="商店" FontWeight="SemiBold" FontSize="13" Foreground="#388E3C"/>
                                                                    <Border Visibility="{Binding ShopFilterMatched, Converter={StaticResource BooleanVisibilityConverter}}"
                                                                            Background="#4CAF50" CornerRadius="3" Padding="6 2" Margin="8 0 0 0">
                                                                        <TextBlock Text="筛选命中" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="角色卡" FontSize="11" Foreground="#666" Margin="0 0 0 2"/>
                                                                <ItemsControl ItemsSource="{Binding ShopCardEntries}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Orientation="Horizontal" Margin="0 2 0 0">
                                                                                <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="#333"/>
                                                                                <TextBlock Text="{Binding PriceDisplay}" FontSize="12" Foreground="#666" Margin="8 0 0 0"/>
                                                                                <TextBlock Text="{Binding DiscountLabel}" FontSize="12" Foreground="#4CAF50" FontWeight="SemiBold" Margin="4 0 0 0"/>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="无色卡" FontSize="11" Foreground="#666" Margin="0 6 0 2"/>
                                                                <ItemsControl ItemsSource="{Binding ShopColorlessEntries}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Orientation="Horizontal" Margin="0 2 0 0">
                                                                                <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="#555" FontStyle="Italic"/>
                                                                                <TextBlock Text="{Binding PriceDisplay}" FontSize="12" Foreground="#666" Margin="8 0 0 0"/>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="遗物" FontSize="11" Foreground="#666" Margin="0 6 0 2"/>
                                                                <ItemsControl ItemsSource="{Binding ShopRelicEntries}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Orientation="Horizontal" Margin="0 2 0 0">
                                                                                <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="#333"/>
                                                                                <TextBlock Text="{Binding PriceDisplay}" FontSize="12" Foreground="#666" Margin="8 0 0 0"/>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="药水" FontSize="11" Foreground="#666" Margin="0 6 0 2"/>
                                                                <ItemsControl ItemsSource="{Binding ShopPotionEntries}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Orientation="Horizontal" Margin="0 2 0 0">
                                                                                <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="#333"/>
                                                                                <TextBlock Text="{Binding PriceDisplay}" FontSize="12" Foreground="#666" Margin="8 0 0 0"/>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <!-- ========== 运行日志页面 ========== -->
                <ScrollViewer x:Name="PageLogsScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24">
                    <Grid x:Name="PageLogs" Visibility="Collapsed">
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="0 0 0 12">
                                    <TextBlock Text="运行日志" FontSize="16" FontWeight="SemiBold" Foreground="#333"/>
                                    <Button Content="清空" Command="{Binding ClearLogsCommand}"
                                            Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <Border Grid.Row="1" Background="#FAFAFA" CornerRadius="4" Padding="12">
                                    <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TimestampText}" Width="60" Foreground="#999" FontSize="11" FontFamily="Consolas"/>
                                                    <Border Background="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                                            CornerRadius="3" Padding="6 2" Margin="0 0 8 0">
                                                        <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#333" FontSize="12"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
                <ScrollViewer x:Name="PageArchiveScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24" Visibility="Collapsed">
                    <views:SeedArchivePage x:Name="PageArchive"/>
                </ScrollViewer>
                <ScrollViewer x:Name="PageViewerScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24" Visibility="Collapsed">
                    <views:SeedViewerPage x:Name="PageViewer"/>
                </ScrollViewer>
            </Grid>
        </Grid>
        <!-- 状态栏 -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#37474F" Padding="16 8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#B0BEC5" FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProgressSaveLoadStatus}" Foreground="#CFD8DC" FontSize="11" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding DatasetSummary}" Foreground="#78909C" FontSize="11" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</hc:Window>
                    
