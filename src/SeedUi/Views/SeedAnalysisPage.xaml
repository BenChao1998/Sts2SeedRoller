<UserControl x:Class="SeedUi.Views.SeedAnalysisPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.1" Color="#000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
        </Style>

        <Style x:Key="EventNameStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="Margin" Value="0 2 0 2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="TextDecorations" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#8A5A00"/>
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventTooltipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#F6E6A9"/>
            <Setter Property="BorderBrush" Value="#B28B2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#3E2B00"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Placement" Value="Mouse"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock Text="种子分析" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0 0 0 16"/>

                <Grid Margin="0 0 0 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0 0 12 0">
                        <TextBlock Text="种子" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                        <TextBox Text="{Binding SeedText, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0 0 12 0">
                        <TextBlock Text="角色" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                        <ComboBox ItemsSource="{Binding CharacterOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedCharacter}"
                                  MinHeight="25"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0 0 12 0">
                        <TextBlock Text="进阶等级" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                        <ComboBox ItemsSource="{Binding AscensionOptions}"
                                  SelectedValue="{Binding SelectedAscensionLevel}"
                                  MinHeight="25"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                        <Button Content="分析"
                                Command="{Binding AnalyzeSeedCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                Padding="20 6"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="{Binding SeedAnalysisSummary}" Foreground="#333" TextWrapping="Wrap" Margin="0 0 0 4"/>
                <TextBlock Text="{Binding SeedAnalysisSeedValueText}" Foreground="#1976D2" FontSize="12"/>

                <Border Margin="0 12 0 0"
                        Padding="12"
                        CornerRadius="6"
                        BorderThickness="1"
                        BorderBrush="#D7CCC8"
                        Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="progress.save 说明"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333"
                                   Margin="0 0 0 8"/>
                        <TextBlock Text="{Binding ProgressSaveLoadStatus}"
                                   Foreground="#8A5A00"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ProgressSaveSummary}"
                                   Foreground="#666"
                                   TextWrapping="Wrap"
                                   Margin="0 6 0 0"/>
                        <TextBlock Text="{Binding ProgressSavePathText}"
                                   Foreground="#666"
                                   TextWrapping="Wrap"
                                   Margin="0 6 0 0"/>
                        <TextBlock Text="{Binding ProgressSaveEpochText}"
                                   Foreground="#666"
                                   TextWrapping="Wrap"
                                   Margin="0 6 0 0"/>
                        <TextBlock Text="{Binding ProgressSaveAncientRuleText}"
                                   Foreground="#666"
                                   TextWrapping="Wrap"
                                   Margin="0 6 0 0"/>
                        <TextBlock Text="说明：程序会读取软件根目录下的 progress.save；若未成功加载，会回退为默认的全解锁古神规则。"
                                   Foreground="#888"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0 8 0 0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="说明：事件和遗物都会优先显示为概率预览，更接近实际跑图时能看到什么。"
                           Foreground="#888"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0 6 0 0"/>
                <TextBlock Text="说明：事件概率更关注实际可见性，主要受地图房型分布、路线画像与途中状态变化影响。"
                           Foreground="#888"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0 8 0 0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock Text="开局选项信息" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0 0 0 12"/>
                <TextBlock Text="这里会显示第一幕 Neow 以及第二、第三幕古神的开局选项。"
                           Foreground="#666"
                           Margin="0 0 0 12"/>

                <ItemsControl ItemsSource="{Binding SeedAnalysisOpeningActs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Header="{Binding Title}" IsExpanded="True" Margin="0 0 0 12">
                                <StackPanel Margin="0 8 0 0">
                                    <TextBlock Text="{Binding AncientDisplay}"
                                               Foreground="#8A5A00"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasAncientDisplay, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <ItemsControl ItemsSource="{Binding Options}" Margin="0 8 0 0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E3D39B"
                                                        BorderThickness="1"
                                                        Background="#FFF9E7"
                                                        CornerRadius="6"
                                                        Padding="10"
                                                        Margin="0 0 0 8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#3E2B00"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Margin="0 4 0 0"
                                                                   Foreground="#5A4300"
                                                                   TextWrapping="Wrap"
                                                                   Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding Note}"
                                                                   Margin="0 6 0 0"
                                                                   Foreground="#8A5A00"
                                                                   TextWrapping="Wrap"
                                                                   Visibility="{Binding HasNote, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        <ItemsControl ItemsSource="{Binding Details}"
                                                                      Margin="0 6 0 0"
                                                                      Visibility="{Binding HasDetails, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding}"
                                                                               Margin="0 2 0 0"
                                                                               Foreground="#444"
                                                                               TextWrapping="Wrap"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock Text="遗物概率预览" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0 0 0 12"/>
                <TextBlock Text="{Binding SeedAnalysisRelicVisibilitySummary}" Foreground="#666" TextWrapping="Wrap" Margin="0 0 0 12"/>
                <TextBlock Text="这里会按不同路线画像做 Monte Carlo 预估，帮助判断哪些遗物更容易在前期看到，哪些遗物整体更可能出现在本局流程中。"
                           Foreground="#888"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0 0 0 12"/>
                <TextBlock Text="路线画像说明：均衡 = 精英与商店分布较均匀；激进 = 更早、更偏向打精英；商店优先 = 更容易经过商店、精英相对更少。"
                           Foreground="#888"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0 0 0 6"/>
                <TextBlock Text="字段说明：出现 = 任意来源看到该遗物的概率；非商店 = 不经过商店看到的概率；商店 = 在商店货架看到的概率；前期 = 在前期窗口内看到的概率；平均首次机会 = 平均第几次遗物机会首次看到；最常来源 = 最常出现的来源类型。"
                           Foreground="#888"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0 0 0 12"/>

                <ItemsControl ItemsSource="{Binding SeedAnalysisRelicVisibilityProfiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Header="{Binding Title}" IsExpanded="False" Margin="0 0 0 12">
                                <StackPanel Margin="0 8 0 0">
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="#666"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <ItemsControl ItemsSource="{Binding ActSummaries}" Margin="0 8 0 0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Margin="0 2 0 2" Foreground="#555" TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Margin="0 12 0 0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0 0 12 0">
                                            <TextBlock Text="更容易前期见到" Style="{StaticResource SectionHeaderStyle}"/>
                                            <ItemsControl ItemsSource="{Binding EarlyRelics}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Text}" Margin="0 2 0 2" Foreground="#444" TextWrapping="Wrap"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="12 0 0 0">
                                            <TextBlock Text="整体更可能出现" Style="{StaticResource SectionHeaderStyle}"/>
                                            <ItemsControl ItemsSource="{Binding SeenRelics}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Text}" Margin="0 2 0 2" Foreground="#444" TextWrapping="Wrap"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0 12 0 0"
                                                Visibility="{Binding HasSamples, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="前期样本序列" Style="{StaticResource SectionHeaderStyle}"/>
                                        <ItemsControl ItemsSource="{Binding SampleLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Margin="0 2 0 2" Foreground="#666" TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0 0 0 16">
            <StackPanel>
                <TextBlock Text="事件概率预览" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0 0 0 12"/>
                <TextBlock Text="{Binding SeedAnalysisEventVisibilitySummary}" Foreground="#666" TextWrapping="Wrap" Margin="0 0 0 12"/>
                <TextBlock Text="这里会按已锁定的事件池加上路线画像做 Monte Carlo 估算，回答的是“这局大概能不能看到它”，而不是每一层地图的精确复盘。系统会先给出一份综合预测，再保留各条路线画像做对照。第二、第三幕古神按幕开场固定可见处理。"
                           Foreground="#888"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0 0 0 12"/>
                <TextBlock Text="路线画像说明：均衡推进 = 按普通实战估算；前压打精英 = 更早打精英、问号更少；偏商店补强 = 更愿意进店，会让事件量略降。"
                           Foreground="#888"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0 0 0 6"/>
                <TextBlock Text="字段说明：前期 = 在前若干次事件机会内首次看到该事件的概率；整局 = 整个流程中至少看到一次的概率；首次约第 N 个事件位 = 平均在第几次事件机会首次看到；多来自 = 更常是问号房还是第二/第三幕开场古神。"
                           Foreground="#888"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0 0 0 12"/>

                <ItemsControl ItemsSource="{Binding SeedAnalysisEventVisibilityProfiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Header="{Binding Title}" IsExpanded="{Binding IsExpandedByDefault, Mode=OneWay}" Margin="0 0 0 12">
                                <StackPanel Margin="0 8 0 0">
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="#666"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <ItemsControl ItemsSource="{Binding ActSummaries}" Margin="0 8 0 0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Margin="0 2 0 2" Foreground="#555" TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Margin="0 12 0 0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0 0 12 0">
                                            <TextBlock Text="更容易前期见到" Style="{StaticResource SectionHeaderStyle}"/>
                                            <ItemsControl ItemsSource="{Binding EarlyEvents}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0 2 0 6">
                                                            <TextBlock Style="{StaticResource EventNameStyle}">
                                                                <Run Text="{Binding RankText, Mode=OneWay}"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{Binding Title, Mode=OneWay}"/>
                                                                <TextBlock.ToolTip>
                                                                    <ToolTip Style="{StaticResource EventTooltipStyle}"
                                                                             Visibility="{Binding HasTooltipContent, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <StackPanel MaxWidth="420">
                                                                            <TextBlock Text="{Binding Description}"
                                                                                       TextWrapping="Wrap"
                                                                                       Foreground="#3E2B00"
                                                                                       Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                            <Border Height="1"
                                                                                    Margin="0 8 0 8"
                                                                                    Background="#C8A24A"
                                                                                    Visibility="{Binding HasDescriptionAndOptions, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                            <StackPanel Visibility="{Binding HasOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                <TextBlock Text="可选项"
                                                                                           FontWeight="SemiBold"
                                                                                           Margin="0 0 0 6"
                                                                                           Foreground="#6D4900"/>
                                                                                <ItemsControl ItemsSource="{Binding Options}">
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <Border Padding="0 0 0 8">
                                                                                                <StackPanel>
                                                                                                    <TextBlock Text="{Binding Title}"
                                                                                                               FontWeight="SemiBold"
                                                                                                               Foreground="#3E2B00"
                                                                                                               TextWrapping="Wrap"/>
                                                                                                    <TextBlock Text="{Binding Description}"
                                                                                                               Margin="0 2 0 0"
                                                                                                               TextWrapping="Wrap"
                                                                                                               Foreground="#3E2B00"
                                                                                                               Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                                                </StackPanel>
                                                                                            </Border>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </ToolTip>
                                                                </TextBlock.ToolTip>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding MetricsText}" Margin="20 2 0 0" Foreground="#666" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="12 0 0 0">
                                            <TextBlock Text="整体更可能出现" Style="{StaticResource SectionHeaderStyle}"/>
                                            <ItemsControl ItemsSource="{Binding SeenEvents}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0 2 0 6">
                                                            <TextBlock Style="{StaticResource EventNameStyle}">
                                                                <Run Text="{Binding RankText, Mode=OneWay}"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{Binding Title, Mode=OneWay}"/>
                                                                <TextBlock.ToolTip>
                                                                    <ToolTip Style="{StaticResource EventTooltipStyle}"
                                                                             Visibility="{Binding HasTooltipContent, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <StackPanel MaxWidth="420">
                                                                            <TextBlock Text="{Binding Description}"
                                                                                       TextWrapping="Wrap"
                                                                                       Foreground="#3E2B00"
                                                                                       Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                            <Border Height="1"
                                                                                    Margin="0 8 0 8"
                                                                                    Background="#C8A24A"
                                                                                    Visibility="{Binding HasDescriptionAndOptions, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                            <StackPanel Visibility="{Binding HasOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                <TextBlock Text="可选项"
                                                                                           FontWeight="SemiBold"
                                                                                           Margin="0 0 0 6"
                                                                                           Foreground="#6D4900"/>
                                                                                <ItemsControl ItemsSource="{Binding Options}">
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <Border Padding="0 0 0 8">
                                                                                                <StackPanel>
                                                                                                    <TextBlock Text="{Binding Title}"
                                                                                                               FontWeight="SemiBold"
                                                                                                               Foreground="#3E2B00"
                                                                                                               TextWrapping="Wrap"/>
                                                                                                    <TextBlock Text="{Binding Description}"
                                                                                                               Margin="0 2 0 0"
                                                                                                               TextWrapping="Wrap"
                                                                                                               Foreground="#3E2B00"
                                                                                                               Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                                                </StackPanel>
                                                                                            </Border>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </ToolTip>
                                                                </TextBlock.ToolTip>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding MetricsText}" Margin="20 2 0 0" Foreground="#666" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0 12 0 0"
                                                Visibility="{Binding HasSamples, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="前期样本序列" Style="{StaticResource SectionHeaderStyle}"/>
                                        <ItemsControl ItemsSource="{Binding SampleLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Margin="0 2 0 2" Foreground="#666" TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
