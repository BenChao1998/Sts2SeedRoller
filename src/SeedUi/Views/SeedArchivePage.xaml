<UserControl x:Class="SeedUi.Views.SeedArchivePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.1" Color="#000"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="0.8*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0 0 12 0">
            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock Text="铺种数据库" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0 0 0 12"/>
                    <TextBlock Text="{Binding ArchiveDatabaseSummary}" Foreground="#333" FontSize="13" Margin="0 0 0 8"/>
                    <TextBlock Text="{Binding ArchiveDatabasePath}" Foreground="#666" FontSize="12" TextWrapping="Wrap" Margin="0 0 0 12"/>
                    <TextBlock Text="{Binding ArchiveJobStatus}" Foreground="#1976D2" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock Text="铺种参数" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0 0 0 16"/>
                    <Grid Margin="0 0 0 12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0 0 8 0">
                            <TextBlock Text="模式" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                            <ComboBox ItemsSource="{Binding ArchiveModeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding SelectedArchiveMode}"
                                      MinHeight="25"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8 0">
                            <TextBlock Text="角色" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                            <ComboBox ItemsSource="{Binding CharacterOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding ArchiveCharacter}"
                                      MinHeight="25"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="8 0 0 0">
                            <TextBlock Text="进阶" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                            <ComboBox ItemsSource="{Binding AscensionOptions}"
                                      SelectedValue="{Binding ArchiveAscension}"
                                      MinHeight="25"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0 0 0 12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0 0 8 0">
                            <TextBlock Text="起始种子" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                            <TextBox Text="{Binding ArchiveSeedText}" Height="30"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8 0">
                            <TextBlock Text="步长" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                            <TextBox Text="{Binding ArchiveSeedStep}" Height="30"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="8 0 0 0">
                            <TextBlock Text="本次数量" FontSize="12" Foreground="#666" Margin="0 0 0 6"/>
                            <TextBox Text="{Binding ArchiveScanCount}" Height="30"/>
                        </StackPanel>
                    </Grid>

                    <WrapPanel Margin="0 0 0 12">
                        <Button Content="开始铺种" Command="{Binding StartArchiveScanCommand}" Style="{StaticResource ButtonPrimary}" Margin="0 0 12 0"/>
                        <Button Content="继续所选任务" Command="{Binding ContinueArchiveScanCommand}" Style="{StaticResource ButtonDefault}" Margin="0 0 12 0"/>
                        <Button Content="停止" Command="{Binding CancelArchiveScanCommand}" Style="{StaticResource ButtonDefault}" Margin="0 0 12 0"/>
                        <Button Content="刷新任务" Command="{Binding RefreshArchiveStateCommand}" Style="{StaticResource ButtonDefault}"/>
                    </WrapPanel>

                    <ProgressBar Value="{Binding ArchiveScannedSeeds, Mode=OneWay}"
                                 Maximum="{Binding ArchiveProgressMaximum, Mode=OneWay}"
                                 Height="6"
                                 Background="#E3F2FD"
                                 Foreground="#1976D2"
                                 Margin="0 0 0 8"/>
                    <TextBlock Text="{Binding ArchiveProgressText}" FontSize="12" Foreground="#666"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="12 0 0 0">
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="最近铺种任务" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0 0 0 12"/>
                    <Border Grid.Row="1" Background="#FAFAFA" CornerRadius="4" Padding="12">
                        <ListBox ItemsSource="{Binding ArchiveJobs}"
                                 SelectedItem="{Binding SelectedArchiveJob}"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding JobId}" FontFamily="Consolas" FontSize="11" Foreground="#666"/>
                                            <TextBlock Text="{Binding Mode}" FontWeight="SemiBold" Foreground="#1976D2" Margin="0 4 0 0"/>
                                            <TextBlock Text="{Binding Character}" Foreground="#333" Margin="0 2 0 0"/>
                                            <TextBlock Text="{Binding Progress}" Foreground="#666" FontSize="12" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding LastSeedText}" Foreground="#999" FontSize="12" Margin="0 2 0 0"/>
                                            <TextBlock Text="{Binding CreatedAt}" Foreground="#999" FontSize="11" Margin="0 2 0 0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
